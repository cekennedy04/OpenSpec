# WorkSpaceRx Frontend Configuration

# API Configuration
VITE_API_BASE_URL=http://localhost:3000/api
VITE_API_TIMEOUT=30000
# Vision analysis is slower than a normal request, so it gets its own budget.
VITE_ANALYSIS_TIMEOUT=120000

# Feature Flags
VITE_ENABLE_CAMERA=true
VITE_ENABLE_FILE_UPLOAD=true
VITE_ENABLE_REPORT_EXPORT=true

# Image Processing
VITE_MAX_IMAGE_SIZE_MB=10
VITE_MIN_IMAGE_WIDTH_PX=640
VITE_MIN_IMAGE_HEIGHT_PX=480
VITE_IMAGE_COMPRESSION_QUALITY=0.8

# Report Storage
VITE_ENABLE_LOCAL_STORAGE=true
VITE_MAX_STORED_REPORTS=50

# Analytics (optional)
VITE_ANALYTICS_ENABLED=false
