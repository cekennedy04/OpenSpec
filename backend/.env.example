# WorkSpaceRx Backend Configuration

# Server
PORT=3000
NODE_ENV=development
HOST=0.0.0.0

# CORS
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# Image Upload
MAX_UPLOAD_SIZE_MB=50
UPLOAD_TIMEOUT_MS=60000
TEMP_UPLOAD_DIR=./temp/uploads

# Analysis
ANALYSIS_QUEUE_ENABLED=true
# Upstream Anthropic API call timeout (ms). Keep this below the frontend's
# VITE_ANALYSIS_TIMEOUT so a stuck call surfaces a clean error.
ANALYSIS_TIMEOUT_MS=90000
# Vision model used for analysis. Sonnet is the fast default; override if needed.
ANALYSIS_MODEL=claude-sonnet-4-6

# Report Storage
REPORT_TEMP_STORAGE_DIR=./temp/reports
REPORT_RETENTION_HOURS=24

# AI Service Integration (to be configured)
# AI_SERVICE_TYPE=openai|custom|other
# AI_SERVICE_API_KEY=***

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Security
API_RATE_LIMIT_WINDOW_MS=15000
API_RATE_LIMIT_MAX_REQUESTS=100
